{
  "permissions": {
    "allow": [
      "mcp__1e29f671-19bc-494a-be75-02ee513cdc38__*"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/vault-log-hook.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/stop-log-hook.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
